rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    // Safe lookup — returns null if the student doc doesn't exist yet
    function myTeamId() {
      let ref = /databases/$(database)/documents/students/$(request.auth.uid);
      return exists(ref) ? get(ref).data.teamId : null;
    }

    // Admin-seeded collections — read only
    match /activities/{id} {
      allow read: if isAuth();
    }

    match /badges/{id} {
      allow read: if isAuth();
    }

    // Teams: any authenticated user can create or join (update adds member email)
    match /teams/{teamId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isAuth();
    }

    // Students: each user owns their own profile doc
    match /students/{uid} {
      allow read: if isAuth();
      allow write: if request.auth.uid == uid;
    }

    // Leaderboard: readable by all, writable by the owning team
    match /leaderboard/{entryId} {
      allow read: if isAuth();
      allow write: if isAuth() && myTeamId() == request.resource.data.team_id;
    }

    // Badge awards
    match /student_badges/{awardId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.resource.data.studentId == request.auth.uid;
    }

    // Activity result collections — create only, no edits or deletes
    match /reactionResults/{resultId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    match /breathingResults/{resultId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    match /handFanResults/{resultId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    match /earthquakeResults/{resultId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    match /ratings/{ratingId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }
  }
}
